# Main RPC / WebSocket URLs
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
BACKUP_RPC_URL=https://api.mainnet-beta.solana.com
# Free Helius RPC pool for non-critical reads (security checks, metadata, WebSocket tx lookups)
# Create 5-6 free Helius accounts at https://dashboard.helius.dev — each gets its own credit pool.
# Comma-separated list — requests rotate round-robin so no single key gets exhausted.
FREE_RPC_URLS=https://mainnet.helius-rpc.com/?api-key=FREE_KEY_1,https://mainnet.helius-rpc.com/?api-key=FREE_KEY_2,https://mainnet.helius-rpc.com/?api-key=FREE_KEY_3,https://mainnet.helius-rpc.com/?api-key=FREE_KEY_4,https://mainnet.helius-rpc.com/?api-key=FREE_KEY_5,https://mainnet.helius-rpc.com/?api-key=FREE_KEY_6
# Max RPC calls per day on paid Helius node (0 = unlimited). Logs warnings when exhausted.
RPC_DAILY_BUDGET=50000
WSS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# Your Wallet Private Key (Base58)
PRIVATE_KEY=your_private_key_here

# Optional: Jupiter API Key (for faster swaps)
JUPITER_API_KEY=your_jupiter_api_key_here

# Birdeye API (for trending/high-volume token discovery)
BIRDEYE_API_KEY=your_birdeye_api_key_here
ADMIN_PASSWORD=your_secure_password_here

# API Security
API_SECRET=your_super_secret_api_key_here
HELIUS_AUTH_SECRET=your_helius_webhook_secret_here

# App Settings
PORT=8080
NODE_ENV=production
DRY_RUN=false
METEORA_POOL_FEE_BPS=200

# Advanced Configuration
BASE_TOKENS='{"LPPP":"44sHXMkPeciUpqhecfCysVs7RcaxeM24VPMauQouBREV","HTP":"2JnYVAeY4gYjRSmGRPQi9EudJm88AT6LgVKeKvxeb9Qp"}'
FEE_RECIPIENT_WALLET=your_recipient_wallet_address_here
FEE_FUNNEL_BUFFER_SOL=0.005
